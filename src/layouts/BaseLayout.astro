---
export interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | VegArchive</title>
    <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <meta name="theme-color" content="#4a7c59" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <style>
      :root {
        --green: #4a7c59;
        --green-light: #6b9f7a;
        --green-dark: #2d5a3b;
        --bg: #faf8f5;
        --bg-card: #ffffff;
        --text: #1a1a1a;
        --text-light: #666;
        --border: #e8e3dc;
        --radius: 12px;
        --shadow: 0 2px 8px rgba(0,0,0,0.06);
        --tag-salato: #d35400;
        --tag-dolce: #c0397a;
        --tag-forno: #e67e22;
        --tag-microonde: #8e44ad;
        --tag-mixer: #2980b9;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      h1 { font-size: 2rem; margin-bottom: 0.5rem; color: var(--green-dark); }
      h2 { font-size: 1.4rem; margin: 2rem 0 0.75rem; color: var(--green-dark); }
      :global(.tag) {
        display: inline-block;
        color: white;
        padding: 0.2rem 0.7rem;
        border-radius: 20px;
        font-size: 0.8rem;
      }
      :global(.tag-salato) { background: var(--tag-salato); }
      :global(.tag-dolce) { background: var(--tag-dolce); }
      :global(.tag-forno) { background: var(--tag-forno); }
      :global(.tag-microonde) { background: var(--tag-microonde); }
      :global(.tag-mixer) { background: var(--tag-mixer); }
      #scrollTop {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 50%;
        background: var(--green);
        color: #fff;
        font-size: 1.3rem;
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s, transform 0.25s;
        box-shadow: var(--shadow);
        z-index: 100;
      }
      #scrollTop.visible {
        opacity: 1;
        pointer-events: auto;
      }
      #scrollTop:hover {
        background: var(--green-dark);
        transform: translateY(-2px);
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>

    <button id="scrollTop" aria-label="Torna su">↑</button>

    <script>
      const base = import.meta.env.BASE_URL || '/';
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(`${base}sw.js`, { scope: base });
        });
      }

      const scrollBtn = document.getElementById('scrollTop');
      if (scrollBtn) {
        window.addEventListener('scroll', () => {
          scrollBtn.classList.toggle('visible', window.scrollY > 400);
        });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
