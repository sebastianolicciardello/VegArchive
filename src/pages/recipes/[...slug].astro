---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(r => ({
    params: { slug: r.slug },
    props: { recipe: r },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);

const { title, author, youtube, tags, date, prepTime, cookTime, totalTime, servings } = recipe.data;
const videoId = youtube.match(/(?:v=|\/)([\w-]{11})/)?.[1];
const authorUrl = youtube.startsWith('https://www.youtube.com')
  ? `https://www.youtube.com/@${author.replace(/\s+/g, '')}`
  : `https://www.youtube.com/results?search_query=${encodeURIComponent(author)}`;
---

<BaseLayout title={title}>
  <article>
    <h1>{title}</h1>
    <p class="meta">
      Di <a href={authorUrl} target="_blank" rel="noopener">{author}</a>
    </p>

    <div class="tags">
      {tags?.map(t => <span class={`tag tag-${t.replace(/\s+/g, '-')}`}>{t}</span>)}
    </div>

    {(date || prepTime || cookTime || totalTime || servings) && (
      <table class="info-table">
        {date && <tr><th>Data</th><td>{date}</td></tr>}
        {prepTime && <tr><th>Preparazione</th><td>{prepTime}</td></tr>}
        {cookTime && <tr><th>Cottura</th><td>{cookTime}</td></tr>}
        {totalTime && <tr><th>Totale</th><td>{totalTime}</td></tr>}
        {servings && <tr><th>Porzioni</th><td>{servings}</td></tr>}
      </table>
    )}

    {videoId && (
      <div class="video-wrapper">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${videoId}`}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    )}

    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .meta {
    color: var(--text-light);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .meta a { color: var(--green); }
  .tags { margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.3rem; }

  .info-table {
    width: 100%;
    max-width: 400px;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .info-table th {
    text-align: left;
    padding: 0.3rem 1rem 0.3rem 0;
    color: var(--text-light);
    font-weight: 500;
  }
  .info-table td { padding: 0.3rem 0; }

  .video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    margin-bottom: 2rem;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
  }

  .content { line-height: 1.8; }
  .content ul, .content ol { padding-left: 1.5rem; margin: 0.75rem 0; }
  .content li { margin-bottom: 0.4rem; }
  .content h2 {
    font-size: 1.4rem;
    margin: 2rem 0 0.75rem;
    color: var(--green-dark);
    border-bottom: 2px solid var(--border);
    padding-bottom: 0.3rem;
  }
  .content h3 {
    font-size: 1.15rem;
    margin: 1.5rem 0 0.5rem;
    color: var(--green-dark);
  }
  .content blockquote {
    border-left: 3px solid var(--green-light);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    background: #f0f5f0;
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--text);
  }
  .content strong { color: var(--green-dark); }
</style>
